{
  "manifest_version": 3,
  "name": "Claude Monitor",
  "version": "1.0.0",
  "description": "Shows token usage, session/weekly limits, cache timer, budget, and usage history on claude.ai.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "css": ["styles.css"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["bridge.js"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "action": {
    "default_title": "Claude Monitor"
  }
}
